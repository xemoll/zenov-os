format=zenpkg-manifest-1
name=compat-xbox-xemu
version=1.0.0
architecture=x86_64
target=x86_64-zenov-linux
kind=compat-profile
entrypoint=-
payload_type=none
runtime=xemu
min_os=0.2.0
license=GPL-2.0
source=https://github.com/xemu-project/xemu
asset_policy=user-supplied
capability=abi.linux.x86_64
capability=kernel.concurrent-processes
capability=kernel.dynamic-linking
capability=gpu.opengl4.0
capability=audio.low-latency
capability=input.gamepad
capability=storage.large-files
